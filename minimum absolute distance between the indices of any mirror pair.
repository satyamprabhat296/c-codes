class Solution {
public:
int revnum(int x){
    int rev=0;
    while(x>0){
        rev= rev*10 + (x%10);
        x/=10;
    }
    return rev;
}
    int minMirrorPairDistance(vector<int>& nums) {
        unordered_map<int,int> lastindex;
        int ans= INT_MAX;
        for(int i=0;i<nums.size();i++){
            if(lastindex.count(nums[i])){
                ans = min(ans, i-lastindex[nums[i]]);
            }
            int rev = revnum(nums[i]);
            lastindex[rev]=i;
            
        }

        return (ans ==INT_MAX) ? -1: ans;
    }
};
