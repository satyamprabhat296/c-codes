class Solution {
  public:
    bool canFormPalindrome(string &s) {
        // code here
             int n=s.size();
        if(n==1){
            return true;
        }
        vector<int> track(26,0);
        for(int i=0;i<n;i++){
            track[s[i]-'a']++;
        }
        int count=0;
        for(int i=0;i<26;i++){
            if(track[i]%2!=0){
                count++;
            }
        }
        if(count<=1){
            return true;
        }
        return false;
    }
};
