class Solution {
public:
    int countMajoritySubarrays(vector<int>& nums, int target) {
        int cnt =0;
        for(int i=0;i<nums.size();i++){
            int countmaj=0;
            for(int j=i;j<nums.size();j++){
                if(nums[j]==target)
                countmaj++;
                if(2*countmaj>j-i+1)
                cnt++;
            }
        }
        return cnt;
    }
};
