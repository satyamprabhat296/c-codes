class Solution {
  public:
    void fizzBuzz(int number) {
 if(number%3==0&&number%5==0){
        cout<<"FizzBuzz"<<endl;
        return ;
    }else if(number%5==0){
        cout<<"Buzz"<<endl;
        return;
    }else if(number%3==0){
        cout<<"Fizz"<<endl;
        return;
    }else{
        cout<<number<<endl;
        return;
    }
    }
};
